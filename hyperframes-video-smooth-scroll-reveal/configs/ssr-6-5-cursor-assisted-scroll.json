        "t": 0,
        "y": 0,
        "s": 1.3
      },
      {
        "t": 0.5,
        "y": 0,
        "s": 1.3
      },
      {
        "t": 3.8,
        "y": 1880,
        "s": 1.3
      },
      {
        "t": 4.3,
        "y": 1880,
        "s": 1.3
      }
    ]
  },
