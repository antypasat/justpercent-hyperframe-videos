<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=1920, height=1080">
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        width: 1920px;
        height: 1080px;
        overflow: hidden;
        background: #080a09;
      }

      body {
        font-family: "Montserrat", "Avenir Next", Arial, sans-serif;
      }

      #root {
        position: relative;
        width: 1920px;
        height: 1080px;
        overflow: hidden;
        color: #fff;
        background: #080a09;
      }

      .clip {
        position: absolute;
        inset: 0;
      }

      .aerial {
        z-index: 0;
        background:
          linear-gradient(90deg, rgba(168, 158, 118, 0.84) 0 37%, rgba(24, 36, 35, 0.94) 37% 70%, rgba(122, 126, 112, 0.92) 70% 100%),
          repeating-linear-gradient(103deg, rgba(255, 255, 255, 0.07) 0 2px, transparent 2px 10px),
          repeating-linear-gradient(7deg, rgba(0, 0, 0, 0.2) 0 3px, transparent 3px 16px);
      }

      .aerial-texture,
      .aerial::after {
        content: "";
        position: absolute;
        inset: -120px;
        background:
          radial-gradient(circle at 19% 26%, rgba(232, 220, 172, 0.24), transparent 19%),
          radial-gradient(circle at 58% 55%, rgba(6, 20, 22, 0.58), transparent 26%),
          repeating-linear-gradient(74deg, rgba(255, 255, 255, 0.105) 0 1px, transparent 1px 9px);
        opacity: 0.85;
        transform: translate3d(0, 0, 0);
      }

      .aerial::after {
        inset: 0 0 0 auto;
        width: 255px;
        background:
          linear-gradient(90deg, rgba(8, 14, 16, 0.72), rgba(72, 68, 58, 0.78) 42%, rgba(122, 116, 94, 0.86)),
          linear-gradient(0deg, transparent 0 41%, rgba(255, 255, 255, 0.18) 41% 42%, transparent 42% 100%);
      }

      .vehicle {
        position: absolute;
        inset: auto;
        right: 48px;
        top: 110px;
        width: 96px;
        height: 190px;
        z-index: 1;
        transform: rotate(1deg);
      }

      .vehicle::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 18px 18px 10px 10px;
        background:
          linear-gradient(90deg, rgba(225, 222, 194, 0.72) 0 16%, transparent 16% 84%, rgba(225, 222, 194, 0.72) 84% 100%),
          linear-gradient(180deg, rgba(52, 112, 84, 0.96), rgba(36, 75, 63, 0.96) 48%, rgba(170, 165, 132, 0.88) 48% 100%);
        box-shadow: 0 34px 36px rgba(0, 0, 0, 0.34);
      }

      .vehicle::after {
        content: "";
        position: absolute;
        left: 18px;
        top: 72px;
        width: 60px;
        height: 46px;
        border: 3px solid rgba(255, 255, 255, 0.28);
        background: rgba(10, 18, 18, 0.56);
      }

      .overlay {
        z-index: 4;
        pointer-events: none;
      }

      .callout {
        position: absolute;
        inset: auto;
        color: #fff;
      }

      .callout svg {
        position: absolute;
        inset: 0;
        overflow: visible;
      }

      .stroke {
        fill: none;
        stroke: rgba(255, 255, 255, 0.94);
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 3;
      }

      .thin {
        stroke-width: 2.4;
      }

      .dot-ring {
        fill: rgba(255, 255, 255, 0.06);
        stroke: rgba(255, 255, 255, 0.96);
        stroke-width: 3;
      }

      .dot-core {
        fill: #fff;
      }

      .mask {
        overflow: hidden;
        padding: 56px 220px 132px 0;
        margin: -56px -220px -132px 0;
      }

      .name {
        font-weight: 800;
        font-size: 86px;
        line-height: 0.9;
        letter-spacing: 0;
        white-space: nowrap;
        text-transform: uppercase;
      }

      .role {
        margin-top: 18px;
        font-size: 42px;
        font-weight: 500;
        line-height: 1;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.9);
        white-space: nowrap;
      }

      #steven {
        left: 72px;
        bottom: 112px;
        width: 1380px;
        height: 610px;
      }

      #steven .steven-copy {
        position: absolute;
        left: 32px;
        bottom: 14px;
      }

      #steven .name {
        font-size: 96px;
      }

      #steven .role {
        font-size: 46px;
        margin-top: 16px;
      }

      #rachel {
        left: 24px;
        top: 28px;
        width: 1790px;
        height: 510px;
      }

      #rachel .rachel-copy {
        position: absolute;
        top: 0;
        right: 306px;
        width: 1260px;
        text-align: right;
      }

      #rachel .name {
        font-size: 94px;
      }

      #rachel .role {
