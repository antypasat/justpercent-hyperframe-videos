        margin-top: 18px;
      }

      #rachel .accent {
        position: absolute;
        top: 0;
        right: 276px;
        display: block;
        width: 14px;
        height: 142px;
        background: rgba(255, 255, 255, 0.98);
        transform-origin: center top;
      }

      #smooth {
        left: 560px;
        top: 42px;
        width: 1200px;
        height: 980px;
      }

      #smooth .circle-copy {
        position: absolute;
        left: 350px;
        top: 218px;
        width: 530px;
        text-align: center;
      }

      #smooth .circle-word {
        display: block;
        font-size: 76px;
        font-weight: 800;
        line-height: 1.2;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      #smooth .circle-word:nth-child(2) {
        font-size: 84px;
      }

      #smooth .circle-word:nth-child(3) {
        font-size: 82px;
      }
    </style>
  </head>
